{
	"name": "totalcms/totalcms",
	"description": "Total CMS - A modern flat-file content management system",
	"type": "project",
	"license": "proprietary",
	"minimum-stability": "dev",
	"prefer-stable": true,
	"require": {
		"php": ">=8.2",
		"totalcms/cms": "^3.5"
	},
	"config": {
		"allow-plugins": {
			"totalcms/cms": true,
			"php-http/discovery": true
		}
	},
	"scripts": {
		"post-create-project-cmd": [
			"@php bin/post-install.php",
			"@php vendor/bin/tcms skill:install"
		],
		"post-install-cmd": [
			"@php vendor/bin/tcms skill:install"
		],
		"post-update-cmd": [
			"@php vendor/bin/tcms skill:install"
		]
	}
}
