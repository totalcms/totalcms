{
	"name": "totalcms/totalcms",
	"description": "Total CMS - A modern flat-file content management system",
	"type": "project",
	"license": "proprietary",
	"minimum-stability": "dev",
	"prefer-stable": true,
	"require": {
		"php": ">=8.2",
		"totalcms/cms": "^3.5",
		"ksubileau/color-thief-php": "dev-fix-deprecations as 2.0.3"
	},
	"repositories": [
		{
			"type": "vcs",
			"url": "https://github.com/joeworkman-forks/color-thief-php.git"
		}
	],
	"config": {
		"allow-plugins": {
			"totalcms/cms": true
		}
	},
	"scripts": {
		"post-create-project-cmd": [
			"@php bin/post-install.php"
		]
	}
}
